PORT=3000
CORS_ORIGIN=http://localhost:5173

# Serper.dev key for MCP tool `search_web`. If unset, backend falls back to Wikipedia only.
SERPER_API_KEY=

# Optional: set a polite User-Agent for Wikipedia requests (recommended in production).
# Example: "ChartStudioBot/1.0 (contact: you@example.com)"
WIKIPEDIA_USER_AGENT=

# Basic in-memory rate limit for `/mcp/*` endpoints
MCP_RATE_LIMIT=60
MCP_RATE_WINDOW_MS=60000

# Backend runs on host and reaches dockerized Postgres via localhost port mapping.
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=postgres

# Set to true/1 when your Postgres requires SSL (common on hosted providers).
DATABASE_SSL=false

JWT_SECRET=please-change-this-secret
JWT_EXPIRES_IN=1d

# Long random string; required for POST /cron/tick (cron-job.org sends X-Cron-Secret).
CRON_SECRET=
